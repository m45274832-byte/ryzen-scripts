local function ToggleKillAura()
    killAuraEnabled = not killAuraEnabled
    if killAuraEnabled then
        if killAuraConnection then killAuraConnection:Disconnect() end
        killAuraConnection = RunService.Heartbeat:Connect(function()
            if not killAuraEnabled then return end
            local closest = nil
            local closestDist = math.huge
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LP and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (HRP.Position - player.Character.HumanoidRootPart.Position).Magnitude
                    if dist < closestDist and dist < 20 then
                        closestDist = dist
                        closest = player
                    end
                end
            end
            if closest then
                killAuraTarget = closest
                local targetPos = closest.Character.HumanoidRootPart.Position
                local radius = 5
                local angleOffset = tick() * 2
                local x = targetPos.X + radius * math.cos(angleOffset)
                local z = targetPos.Z + radius * math.sin(angleOffset)
                HRP.CFrame = CFrame.new(x, HRP.Position.Y, z) * CFrame.lookAt(Vector3.new(x, HRP.Position.Y, z), targetPos)
            else
                killAuraTarget = nil
            end
        end)
    else
        if killAuraConnection then
            killAuraConnection:Disconnect()
            killAuraConnection = nil
        end
        killAuraTarget = nil
        ShowMessage("KillAura OFF")
    end
end

